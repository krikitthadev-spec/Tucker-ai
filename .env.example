# Tucker AI Configuration

# API Keys (get these from the services)
OPENAI_API_KEY=sk_your_key_here
ANTHROPIC_API_KEY=sk_your_key_here

# ADB Configuration
ADB_PORT=5037
ADB_HOST=localhost
TABLET_IP=192.168.1.100  # Change to your tablet's IP
TABLET_PORT=5555

# AI Configuration
AI_MODEL=gpt-3.5-turbo  # or claude-2, or local model
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000

# App Package Names (customize for your apps)
BROWSER_APP=com.android.chrome
YOUTUBE_APP=com.google.android.youtube
SEARCH_ENGINE=com.google.android.googlequicksearchbox

# Debug Mode
DEBUG=False
DEBUG_SCREENSHOTS=False
